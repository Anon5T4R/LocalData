{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalData",
  "version": "0.7.0",
  "identifier": "com.localdata.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalData",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "resources": ["binaries/llama/*"],
    "fileAssociations": [
      {
        "ext": ["tbase"],
        "name": "Base de dados",
        "description": "Base de dados do LocalData",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
